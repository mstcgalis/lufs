#!/usr/bin/env zsh
#
# lufs — LUFS analysis and track comparison for audio files
# https://github.com/mstcgalis/lufs

setopt pipe_fail no_unset

readonly VERSION="1.2.7"

lufs() {
  local sort_by="name"
  local sort_explicit=0
  local use_cache=1
  local show_info=0
  local use_target=0
  local target_lufs="" target_name=""
  local -a files

  while [[ ${1:-} == -* ]]; do
    case $1 in
      -s|--sort)
        sort_by=$2; sort_explicit=1; shift 2 ;;
      --no-cache)
        use_cache=0; shift ;;
      -t|--target)
        use_target=1
        case "${2:l}" in
          spotify|youtube|tidal|soundcloud) target_lufs="-14"; target_name="${2:l}" ;;
          apple|apple-music)                target_lufs="-16"; target_name="apple music" ;;
          *)
            target_lufs="$2"
            [[ "$target_lufs" != -* ]] && target_lufs="-${target_lufs}" ;;
        esac
        shift 2 ;;
      -i|--info)
        show_info=1; shift ;;
      -v|--version)
        echo "lufs $VERSION"; return 0 ;;
      -h|--help)
        cat <<'HELP'
Usage: lufs [-s integrated|peak|st|lra|name] [-t TARGET] [--no-cache] [-i|--info] [files...]

Analyze LUFS loudness of audio files using ffmpeg.

Options:
  -s, --sort COL    Sort by: integrated, peak, st, lra, name (default: name)
  -t, --target LVL  Compare against target: number or spotify/apple/youtube/tidal
  -i, --info        Show bit depth and sample rate
  --no-cache        Force re-analysis of all files
  -v, --version     Show version
  -h, --help        Show this help

With no file arguments, analyzes all audio files in the current directory.
Supported formats: wav, flac, aiff, mp3, ogg, opus, m4a, wma
Results are cached per-directory in .lufs_cache (keyed by file modification time).

For 2+ files, shows summary stats and flags:
  - TP warnings (true peak > -0.1 dBFS)
  - LRA outliers (> 3 LU from median)
  - Loudness outliers (> 1 LU from median integrated)
  - Mono files

Requires: ffmpeg (with ebur128 filter)
HELP
        return 0 ;;
      *) echo "Unknown flag: $1"; return 1 ;;
    esac
  done

  if (( $# )); then
    files=("$@")
  else
    files=(*.wav(N) *.flac(N) *.aiff(N) *.aif(N) *.mp3(N) *.ogg(N) *.opus(N) *.m4a(N) *.wma(N))
    if (( ! ${#files} )); then
      echo "No audio files found in current directory"
      return 1
    fi
  fi

  # check for ffmpeg
  if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg is required but not found in PATH"
    return 1
  fi

  # color helpers
  local c_red=$'\033[31m' c_yel=$'\033[33m' c_dim=$'\033[2m' c_rst=$'\033[0m'

  local cache_file=".lufs_cache"
  local -A cache_mtime cache_int cache_peak cache_lra cache_st cache_depth cache_sr cache_ch cache_size cache_dur
  local -A content_key_map  # "mtime:size:dur" -> cached filename, for rename detection

  # load existing cache
  if (( use_cache )) && [[ -f $cache_file ]]; then
    while IFS=$'\t' read -r c_file c_mtime c_int c_peak c_lra c_st c_depth c_sr c_ch c_size c_dur; do
      cache_mtime[$c_file]=$c_mtime
      cache_int[$c_file]=$c_int; cache_peak[$c_file]=$c_peak
      cache_lra[$c_file]=$c_lra; cache_st[$c_file]=$c_st
      cache_depth[$c_file]=$c_depth
      cache_sr[$c_file]=$c_sr; cache_ch[$c_file]=$c_ch
      cache_size[$c_file]=$c_size; cache_dur[$c_file]=$c_dur
      [[ -n "$c_mtime" && -n "$c_size" && -n "$c_dur" ]] && content_key_map["${c_mtime}:${c_size}:${c_dur}"]=$c_file
    done < "$cache_file"
  fi

  local -a rows
  local -A int_map st_map peak_map lra_map depth_map sr_map ch_map size_map dur_map
  local cached=0 analyzed=0
  local total=${#files}
  local current=0

  for f in "${files[@]}"; do
    (( current++ ))
    local mtime=$(stat -f '%m' "$f" 2>/dev/null)
    local size=$(stat -f '%z' "$f" 2>/dev/null)
    size_map[$f]=$size

    if (( use_cache )) && [[ -n "${cache_mtime[$f]:-}" && "${cache_mtime[$f]:-}" == "$mtime" ]]; then
      int_map[$f]=${cache_int[$f]}; peak_map[$f]=${cache_peak[$f]}
      lra_map[$f]=${cache_lra[$f]}; st_map[$f]=${cache_st[$f]}
      depth_map[$f]=${cache_depth[$f]}
      sr_map[$f]=${cache_sr[$f]}; ch_map[$f]=${cache_ch[$f]}
      dur_map[$f]=${cache_dur[$f]:-}
      (( cached++ ))
      continue
    fi

    # quick metadata probe for duration (needed for rename detection content key)
    local probe; probe=$(ffmpeg -i "$f" 2>&1 || true)
    local dur=$(echo "$probe" | grep -oE 'Duration: [0-9:\.]+' | head -1 | awk '{print $2}')
    local content_key="${mtime}:${size}:${dur}"

    if (( use_cache )) && [[ -n "${content_key_map[$content_key]:-}" ]]; then
      local orig="${content_key_map[$content_key]}"
      int_map[$f]=${cache_int[$orig]}; peak_map[$f]=${cache_peak[$orig]}
      lra_map[$f]=${cache_lra[$orig]}; st_map[$f]=${cache_st[$orig]}
      depth_map[$f]=${cache_depth[$orig]}
      sr_map[$f]=${cache_sr[$orig]}; ch_map[$f]=${cache_ch[$orig]}
      dur_map[$f]=$dur
      (( cached++ ))
      continue
    fi

    printf "${c_dim}analyzing %d/%d: %s${c_rst}\n" "$current" "$total" "${f:t}" >&2
    result=$(ffmpeg -i "$f" -filter:a ebur128=peak=true -f null /dev/null 2>&1)
    local i=$(echo "$result" | grep -E "^\s+I:"    | awk '{print $2}')
    local p=$(echo "$result" | grep -E "^\s+Peak:"  | awk '{print $2}')
    local l=$(echo "$result" | grep -E "^\s+LRA:"   | awk '{print $2}')
    local s=$(echo "$result" | grep -oE 'S: *-?[0-9]+\.[0-9]+' | sed 's/^S: *//' | sort -g | tail -1)

    local audio_line=$(echo "$result" | grep -E 'Audio:' | head -1)
    local bd=$(echo "$audio_line" | grep -oE '(s|u|f)(16|24|32|64)(le|be|p)?' | head -1)
    local sr=$(echo "$audio_line" | grep -oE '[0-9]+ Hz' | head -1 | awk '{print $1}')
    local ch=$(echo "$audio_line" | grep -oE '(mono|stereo|[0-9]+\.[0-9]+)' | head -1)
    case $bd in
      *16*) bd="16" ;; *24*) bd="24" ;; *32*) bd="32" ;; *64*) bd="64" ;; *) bd="-" ;;
    esac

    int_map[$f]=$i; st_map[$f]=$s; peak_map[$f]=$p; lra_map[$f]=$l
    depth_map[$f]=$bd; sr_map[$f]=$sr; ch_map[$f]=$ch; dur_map[$f]=$dur

    cache_mtime[$f]=$mtime; cache_int[$f]=$i; cache_peak[$f]=$p
    cache_lra[$f]=$l; cache_st[$f]=$s
    cache_depth[$f]=$bd
    cache_sr[$f]=$sr; cache_ch[$f]=$ch
    (( analyzed++ ))
  done

  (( analyzed > 0 )) && echo "" >&2

  # write cache
  if (( use_cache )); then
    : > "$cache_file"
    local -A _current_set
    for f in "${files[@]}"; do _current_set[$f]=1; done
    # write current files
    for f in "${files[@]}"; do
      local mtime=$(stat -f '%m' "$f" 2>/dev/null)
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$f" "$mtime" "${int_map[$f]}" "${peak_map[$f]}" "${lra_map[$f]}" "${st_map[$f]}" \
        "${depth_map[$f]}" "${sr_map[$f]}" "${ch_map[$f]}" "${size_map[$f]}" "${dur_map[$f]:-}" >> "$cache_file"
    done
    # preserve cached entries for other files that still exist (not re-analyzed this run)
    for cf in "${(k)cache_mtime[@]}"; do
      [[ -n "${_current_set[$cf]:-}" ]] && continue
      [[ ! -f "$cf" ]] && continue
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$cf" "${cache_mtime[$cf]}" "${cache_int[$cf]}" "${cache_peak[$cf]}" \
        "${cache_lra[$cf]}" "${cache_st[$cf]}" "${cache_depth[$cf]}" \
        "${cache_sr[$cf]}" "${cache_ch[$cf]}" "${cache_size[$cf]:-}" "${cache_dur[$cf]:-}" >> "$cache_file"
    done
    (( cached + analyzed > 0 )) && echo "${c_dim}($analyzed analyzed, $cached cached)${c_rst}"
    echo ""
  fi

  # sort
  local -a sorted
  _lufs_sort() {
    local -A map; local key=$1; shift
    case $key in
      integrated) map=("${(@kv)int_map}") ;;
      peak)       map=("${(@kv)peak_map}") ;;
      st)         map=("${(@kv)st_map}") ;;
      lra)        map=("${(@kv)lra_map}") ;;
    esac
    sorted=()
    while IFS=$'\t' read -r _ fname; do
      sorted+=("$fname")
    done < <(for f in "$@"; do printf '%s\t%s\n' "${map[$f]}" "$f"; done | sort -g)
  }
  case $sort_by in
    integrated|peak|st|lra) _lufs_sort "$sort_by" "${files[@]}" ;;
    name)
      sorted=()
      if (( sort_explicit )); then
        # explicit -s name: always alphabetical
        while IFS=$'\t' read -r _ fname; do
          sorted+=("$fname")
        done < <(for f in "${files[@]}"; do printf '%s\t%s\n' "${f:t:r}" "$f"; done | sort -f)
      else
        # smart default: numeric prefix → numeric sort, else by INT
        local num_prefixed=0
        for f in "${files[@]}"; do
          local _lead="${${f:t:r}%%[^0-9]*}"
          [[ -n "$_lead" ]] && (( num_prefixed++ ))
        done
        if (( num_prefixed * 2 > ${#files} )); then
          while IFS=$'\t' read -r _ fname; do
            sorted+=("$fname")
          done < <(for f in "${files[@]}"; do
            local lead="${${f:t:r}%%[^0-9]*}"
            printf '%s\t%s\n' "${lead:-0}" "$f"
          done | sort -n -t$'\t' -k1)
        else
          while IFS=$'\t' read -r _ fname; do
            sorted+=("$fname")
          done < <(for f in "${files[@]}"; do printf '%s\t%s\n' "${int_map[$f]}" "$f"; done | sort -g)
        fi
      fi
      ;;
    *)                       sorted=("${files[@]}") ;;
  esac
  unfunction _lufs_sort 2>/dev/null

  # find max filename length for padding (capped at 58 chars)
  local max_len=5
  local max_name_len=58
  for f in "${sorted[@]}"; do
    local name="${f:t:r}"
    (( ${#name} > max_len )) && max_len=${#name}
  done
  (( max_len > max_name_len )) && max_len=$max_name_len

  # extend max_len if truncated names collide
  local _collision=1
  while (( _collision && max_len < max_name_len )); do
    _collision=0
    local -A _seen_trunc
    for f in "${sorted[@]}"; do
      local _n="${f:t:r}"
      local _t; _t=$(( ${#_n} > max_len )) && _t="${_n[1,$((max_len-1))]}…" || _t="$_n"
      if [[ -n "${_seen_trunc[$_t]:-}" ]]; then _collision=1; (( max_len++ )); break; fi
      _seen_trunc[$_t]=1
    done
  done

  # truncate name to max_len, adding … if needed
  _trunc() {
    local n="$1"
    if (( ${#n} > max_len )); then
      echo "${n[1,$((max_len-1))]}…"
    else
      echo "$n"
    fi
  }

  # header + rows
  local header
  if (( show_info )); then
    if (( use_target )); then
      header="$(printf "%-${max_len}s   INT      TP       ST MAX   LRA      DELTA    BITS   RATE" "TRACK")"
    else
      header="$(printf "%-${max_len}s   INT      TP       ST MAX   LRA      BITS   RATE" "TRACK")"
    fi
  else
    if (( use_target )); then
      header="$(printf "%-${max_len}s   INT      TP       ST MAX   LRA      DELTA" "TRACK")"
    else
      header="$(printf "%-${max_len}s   INT      TP       ST MAX   LRA" "TRACK")"
    fi
  fi
  if (( use_target )); then
    local target_label="$target_lufs LUFS"
    [[ -n "$target_name" ]] && target_label+="  ($target_name)"
    printf "${c_dim}target: %s${c_rst}\n" "$target_label"
  fi
  echo "${c_dim}${header}${c_rst}"
  printf '%*s\n' "${#header}" '' | tr ' ' '─'

  for f in "${sorted[@]}"; do
    local name="$(_trunc "${f:t:r}")"
    local mono_flag=""
    [[ "${ch_map[$f]}" == "mono" ]] && mono_flag=" ${c_yel}[MONO]${c_rst}"
    local delta_str=""
    if (( use_target )); then
      local _dv _da _dr _dp
      _dv=$(echo "${int_map[$f]} - ($target_lufs)" | bc -l)
      _da=$(echo "if ($_dv < 0) -1*$_dv else $_dv" | bc -l)
      _dr=$(printf "%+.1f" "$_dv")
      _dp=$(printf "%-8s" "$_dr")
      if (( $(echo "$_da <= 1.0" | bc -l) )); then
        delta_str="${c_grn}${_dp}${c_rst}"
      elif (( $(echo "$_da <= 3.0" | bc -l) )); then
        delta_str="${c_yel}${_dp}${c_rst}"
      else
        delta_str="${c_red}${_dp}${c_rst}"
      fi
    fi
    if (( show_info )); then
      local sr_display="${sr_map[$f]}"
      if [[ -n "$sr_display" ]]; then
        sr_display="$(echo "scale=1; $sr_display / 1000" | bc)k"
      fi
      if (( use_target )); then
        printf "%-${max_len}s   %-8s %-8s %-8s %-8s %s %-6s %s%s\n" \
          "$name" "${int_map[$f]}" "${peak_map[$f]}" "${st_map[$f]}" "${lra_map[$f]}" \
          "$delta_str" "${depth_map[$f]}" "$sr_display" "$mono_flag"
      else
        printf "%-${max_len}s   %-8s %-8s %-8s %-8s %-6s %s%s\n" \
          "$name" "${int_map[$f]}" "${peak_map[$f]}" "${st_map[$f]}" "${lra_map[$f]}" \
          "${depth_map[$f]}" "$sr_display" "$mono_flag"
      fi
    else
      if (( use_target )); then
        printf "%-${max_len}s   %-8s %-8s %-8s %-8s %s%s\n" \
          "$name" "${int_map[$f]}" "${peak_map[$f]}" "${st_map[$f]}" "${lra_map[$f]}" \
          "$delta_str" "$mono_flag"
      else
        printf "%-${max_len}s   %-8s %-8s %-8s %s%s\n" \
          "$name" "${int_map[$f]}" "${peak_map[$f]}" "${st_map[$f]}" "${lra_map[$f]}" "$mono_flag"
      fi
    fi
  done

  # summary for 2+ files
  if (( ${#files} > 1 )); then
    local i_vals=($(for f in "${files[@]}"; do echo "${int_map[$f]}"; done | sort -g))
    local s_vals=($(for f in "${files[@]}"; do echo "${st_map[$f]}"; done | sort -g))
    local p_vals=($(for f in "${files[@]}"; do echo "${peak_map[$f]}"; done | sort -g))
    local l_vals=($(for f in "${files[@]}"; do echo "${lra_map[$f]}"; done | sort -g))

    local i_range=$(echo "${i_vals[-1]} - ${i_vals[1]}" | bc -l)
    local s_range=$(echo "${s_vals[-1]} - ${s_vals[1]}" | bc -l)
    local p_max=${p_vals[-1]}

    echo ""
    printf "Integrated range: %.1f LU  |  ST max range: %.1f LU  |  TP ceiling: %s dBFS\n" \
      "$i_range" "$s_range" "$p_max"

    # TP outliers
    local has_tp_outliers=0
    for f in "${sorted[@]}"; do
      local tp=${peak_map[$f]}
      if (( $(echo "$tp > -0.1" | bc -l) )); then
        if (( ! has_tp_outliers )); then
          echo ""
          echo "${c_red}TP warnings (> -0.1 dBFS):${c_rst}"
          has_tp_outliers=1
        fi
        printf "  ${c_red}%-${max_len}s  %s dBFS${c_rst}\n" "$(_trunc "${f:t:r}")" "$tp"
      fi
    done

    # LRA outliers
    local lra_median=${l_vals[$(( (${#l_vals} + 1) / 2 ))]}
    local -a lra_outlier_rows
    for f in "${sorted[@]}"; do
      local diff=$(echo "${lra_map[$f]} - $lra_median" | bc -l)
      local abs_diff=$(echo "if ($diff < 0) -1*$diff else $diff" | bc -l)
      if (( $(echo "$abs_diff > 3.0" | bc -l) )); then
        lra_outlier_rows+=("${abs_diff}"$'\t'"${f}"$'\t'"${diff}")
      fi
    done
    if (( ${#lra_outlier_rows} > 0 )); then
      echo ""
      echo "${c_yel}LRA outliers (> 3 LU from median):${c_rst}"
      while IFS=$'\t' read -r _abs _f _diff; do
        printf "  ${c_yel}%-${max_len}s  %+.1f LU${c_rst}\n" "$(_trunc "${_f:t:r}")" "$_diff"
      done < <(printf '%s\n' "${lra_outlier_rows[@]}" | sort -rg -t$'\t' -k1)
    fi

    # loudness outliers
    local median=${i_vals[$(( (${#i_vals} + 1) / 2 ))]}
    local -a loudness_outlier_rows
    for f in "${sorted[@]}"; do
      local diff=$(echo "${int_map[$f]} - $median" | bc -l)
      local abs_diff=$(echo "if ($diff < 0) -1*$diff else $diff" | bc -l)
      if (( $(echo "$abs_diff > 1.0" | bc -l) )); then
        loudness_outlier_rows+=("${abs_diff}"$'\t'"${f}"$'\t'"${diff}")
      fi
    done
    if (( ${#loudness_outlier_rows} > 0 )); then
      echo ""
      echo "${c_yel}Loudness outliers (> 1 LU from median):${c_rst}"
      while IFS=$'\t' read -r _abs _f _diff; do
        printf "  ${c_yel}%-${max_len}s  %+.1f LU${c_rst}\n" "$(_trunc "${_f:t:r}")" "$_diff"
      done < <(printf '%s\n' "${loudness_outlier_rows[@]}" | sort -rg -t$'\t' -k1)
    fi
  fi

  unfunction _trunc 2>/dev/null
}

lufs "$@"
